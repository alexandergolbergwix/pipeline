# Model weights (too large for GitHub — bundled in .app instead)
ner/*.pt
ner/*.pkl
ner/joint_entity_role_model/
ner/provenance_model_kfold/
ner/contents_model_kfold/

# Training-data caches (large; regenerated from source TSVs)
data/tsvs/genre_samples.tsv
data/tsvs/marc500_sentences.tsv
data/tsvs/filtered_manuscripts_after_906a.tsv

# LaTeX build artifacts
paper/*.aux
paper/*.fdb_latexmk
paper/*.fls
paper/*.out
paper/*.pdf

# Reference PDFs (large)
docs/*.pdf

# Sensitive / external
paper/literature/
docs/mails from experts/

# Verification working state (large; regenerated by verify_paper.py)
paper/verification/results/
paper/verification/audit/

# Coding-agent transient state
.codex/
.github/ai/
.claude/scheduled_tasks.lock

# Build artifacts
dist/
*.dmg

# Python bytecache
__pycache__/
*.pyc

# Logs
*.log
.coverage

# macOS
.DS_Store

# Data files (large)
data/kima/kima_index.db

# Secrets / credentials — NEVER commit these
*.token
*token*.txt
*.env
.env.*
*credentials*.json
secrets/
.claude/secrets/

# Audit / revert working files (may contain QID lists or bearer-token cmd lines)
/tmp/wd_token.txt
audit_*.json.bak
revert_*.log

        <rdfs:label xml:lang="en">has created</rdfs:label>
        <rdfs:label xml:lang="he">יצר</rdfs:label>
      </owl:ObjectProperty>
    </rdfs:subPropertyOf>
    <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F27_Work_Creation"/>

  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://iflastandards.info/ns/lrm/lrmoo/R16_created">
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P94_has_created">

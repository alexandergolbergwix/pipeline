  <owl:Class rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#CompositeCodicologicalUnit">
    <rdfs:subClassOf rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="naef5fc606f664b668240f041396d1f43b200">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
          <owl:Restriction rdf:nodeID="naef5fc606f664b668240f041396d1f43b201">
            <owl:onProperty>
              <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_sub_unit">
                <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
                <rdfs:domain rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
                <rdfs:range rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
                <rdfs:label xml:lang="en">has sub-unit</rdfs:label>
                <rdfs:label xml:lang="he">מכיל תת-יחידה</rdfs:label>
                <rdfs:comment xml:lang="en">Links a codicological unit to its nested sub-units. Transitive property allowing arbitrary nesting depth.</rdfs:comment>
              </owl:ObjectProperty>
            </owl:onProperty>
            <owl:someValuesFrom rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:label xml:lang="en">Composite Codicological Unit</rdfs:label>
    <rdfs:label xml:lang="he">יחידה קודיקולוגית מורכבת</rdfs:label>
    <rdfs:comment xml:lang="en">A codicological unit that contains sub-units (not atomic)</rdfs:comment>
    <owl:disjointWith rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#AtomicCodicologicalUnit"/>
  </owl:Class>

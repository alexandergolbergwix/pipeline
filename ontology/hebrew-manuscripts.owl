  <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P29_custody_received_by">
    <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E10_Transfer_of_Custody"/>
    <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E39_Actor"/>
    <rdfs:label xml:lang="en">custody received by</rdfs:label>
    <rdfs:label xml:lang="he">קיבל משמורת</rdfs:label>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Later_hand_type">
    <rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E55_Type"/>
    <rdfs:label xml:lang="en">Later Hand</rdfs:label>
    <rdfs:label xml:lang="he">יד מאוחרת</rdfs:label>
  </owl:NamedIndividual>
  <owl:DatatypeProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#is_primary_paradigm">
    <rdfs:domain rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#ManuscriptView"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label xml:lang="en">is primary paradigm</rdfs:label>
    <rdfs:label xml:lang="he">פרדיגמה עיקרית</rdfs:label>
    <rdfs:comment xml:lang="en">Whether this is the primary/preferred paradigm for this MS</rdfs:comment>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_parent_unit">
    <rdfs:subPropertyOf>
      <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#is_sub_unit_of">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <owl:inverseOf rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_sub_unit"/>
        <rdfs:domain rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
        <rdfs:range rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>
        <rdfs:label xml:lang="en">is sub-unit of</rdfs:label>
        <rdfs:label xml:lang="he">תת-יחידה של</rdfs:label>
        <rdfs:comment xml:lang="en">Links a codicological unit to its parent unit in the hierarchy</rdfs:comment>

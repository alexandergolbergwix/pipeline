    <rdfs:label xml:lang="he">מיקום ההתערבות</rdfs:label>
    <rdfs:comment xml:lang="en">Links a scribal intervention to its location in the manuscript</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#is_translation_of">
    <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F1_Work"/>

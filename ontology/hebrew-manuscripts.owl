  <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#is_volume_of">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_volume">
        <owl:inverseOf rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#is_volume_of"/>
        <rdfs:domain rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#MultiVolumeSet"/>
        <rdfs:range rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F4_Manifestation_Singleton"/>
        <rdfs:label xml:lang="en">has volume</rdfs:label>
        <rdfs:label xml:lang="he">כולל כרך</rdfs:label>
        <rdfs:comment xml:lang="en">Links a multi-volume set to one of its constituent volumes</rdfs:comment>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F4_Manifestation_Singleton"/>
    <rdfs:range rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#MultiVolumeSet"/>
    <rdfs:label xml:lang="en">is volume of</rdfs:label>
    <rdfs:label xml:lang="he">כרך של</rdfs:label>
    <rdfs:comment xml:lang="en">Links a physical volume to the multi-volume set it belongs to. Declared Functional: each volume belongs to at most one set. If a volume is asserted in two sets the reasoner will infer those sets are identical.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://iflastandards.info/ns/lrm/lrmoo/F27_Work_Creation">

              <owl:Restriction rdf:nodeID="naef5fc606f664b668240f041396d1f43b206">
                <owl:onProperty rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_sub_unit"/>
                <owl:someValuesFrom rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Codicological_Unit"/>

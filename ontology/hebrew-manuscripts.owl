        <rdfs:label xml:lang="he">סופר מוזכר</rdfs:label>
        <rdfs:comment xml:lang="en">Links a colophon to the scribe it mentions</rdfs:comment>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E21_Person"/>
    <rdfs:range rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#Colophon"/>

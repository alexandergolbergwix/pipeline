  <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#has_related_material">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F4_Manifestation_Singleton"/>
    <rdfs:range rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F4_Manifestation_Singleton"/>
    <rdfs:label xml:lang="en">has related material</rdfs:label>
    <rdfs:label xml:lang="he">יש חומר קשור</rdfs:label>
    <rdfs:comment xml:lang="en">Links a manuscript to related materials (other copies, fragments, related texts). Derived from MARC 544 field. Bidirectional.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#intervention_location">
    <rdfs:domain rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#ScribalIntervention"/>
    <rdfs:range rdf:resource="http://www.ontology.org.il/HebrewManuscripts/2025-12-06#TextLocation"/>
